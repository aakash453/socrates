      "generator": "Visual Studio 17 2022",
      "architecture": "ARM64",
      "binaryDir": "${sourceDir}/build/windows-arm64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SOCRATES_ENABLE_TESTS": "OFF",
        "SOCRATES_ENABLE_TOOLS": "ON",
        "SOCRATES_ENABLE_QNN": "ON",
        "SOCRATES_ENABLE_LITERT": "ON",
        "SOCRATES_ENABLE_MLX": "OFF",
        "SOCRATES_ENABLE_LLAMA": "ON",
        "SOCRATES_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "windows-x64-release",
      "displayName": "Windows x64 Release",
      "description": "Release for Windows x64 \u2014 LiteRT DirectML GPU + AVX2 CPU",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/windows-x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SOCRATES_ENABLE_TESTS": "ON",
        "SOCRATES_ENABLE_TOOLS": "ON",
        "SOCRATES_ENABLE_QNN": "OFF",
        "SOCRATES_ENABLE_LITERT": "ON",
        "SOCRATES_ENABLE_LLAMA": "ON",
        "SOCRATES_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "linux-arm64-release",
      "displayName": "Linux ARM64 Release (Raspberry Pi 5 / Jetson)",
      "description": "Release for Linux ARM64 \u2014 NEON SIMD + CPU",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/linux-arm64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SOCRATES_ENABLE_TESTS": "OFF",
        "SOCRATES_ENABLE_TOOLS": "ON",
        "SOCRATES_ENABLE_QNN": "OFF",
        "SOCRATES_ENABLE_MLX": "OFF",
        "SOCRATES_ENABLE_LITERT": "OFF",
        "SOCRATES_ENABLE_LLAMA": "ON",
        "SOCRATES_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "linux-x64-release",
