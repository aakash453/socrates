{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "macos-debug",
      "displayName": "macOS Debug (M1-M4)",
      "description": "Debug build for Apple Silicon with Metal GPU + Neural Engine + AMX",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/conan-debug/conan_toolchain.cmake",
        "SOCRATES_ENABLE_TESTS": "ON",
        "SOCRATES_ENABLE_TOOLS": "ON",
        "SOCRATES_ENABLE_QNN": "OFF",
        "SOCRATES_ENABLE_MLX": "ON",
        "SOCRATES_ENABLE_LLAMA": "ON",
        "SOCRATES_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "macos-release",
      "displayName": "macOS Release (M1-M4 Optimized)",
      "description": "Release build for Apple Silicon \u2014 Metal GPU + AMX coprocessor, LTO",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/conan-release/conan_toolchain.cmake",
        "SOCRATES_ENABLE_TESTS": "OFF",
        "SOCRATES_ENABLE_TOOLS": "ON",
        "SOCRATES_ENABLE_QNN": "OFF",
        "SOCRATES_ENABLE_MLX": "ON",
        "SOCRATES_ENABLE_LLAMA": "ON",
        "SOCRATES_WARNINGS_AS_ERRORS": "ON"
      }
    },
    {
      "name": "windows-arm64-release",
      "displayName": "Windows ARM64 Release (Snapdragon X Elite)",
