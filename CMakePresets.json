        "SOCRATES_ENABLE_QNN": "ON",
        "SOCRATES_ENABLE_LITERT": "ON",
        "SOCRATES_ENABLE_EXECUTORCH": "ON",
        "SOCRATES_WARNINGS_AS_ERRORS": "OFF"
      }
    }
